# BaaS environment example.
# Copy this file to .env.local for local development and replace placeholders.
# Never commit real secrets.

# Shared Supabase project metadata
SUPABASE_PROJECT_REF=efcyejbvcskbnipwdfge
SUPABASE_URL=https://efcyejbvcskbnipwdfge.supabase.co

# Mobile / client-safe values
EXPO_PUBLIC_SUPABASE_URL=https://efcyejbvcskbnipwdfge.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-publishable-key
EXPO_PUBLIC_API_BASE_URL=https://baas-project-production.up.railway.app
# Comma-separated login channels. Production default: email only (WhatsApp OTP deferred).
EXPO_PUBLIC_AUTH_LOGIN_CHANNELS=email

# Server-only values
# Use only in NestJS API, backend jobs, CI, or deployment secret stores.
API_PORT=3000
# Required for Expo Web (Chrome) calling the API. Example for local dev ports:
# BAAS_CORS_ALLOWED_ORIGINS=http://localhost:8153,http://localhost:8152,http://localhost:8081
BAAS_CORS_ALLOWED_ORIGINS=
BAAS_RATE_LIMIT_MAX=300
BAAS_RATE_LIMIT_TTL_MS=60000
BAAS_WEBHOOK_RATE_LIMIT_MAX=120
BAAS_WEBHOOK_RATE_LIMIT_TTL_MS=60000
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_ACCESS_TOKEN=replace-with-supabase-access-token
SUPABASE_DB_PASSWORD=replace-with-database-password
WHATSAPP_VERIFY_TOKEN=replace-with-webhook-verify-token
WHATSAPP_APP_SECRET=replace-with-meta-app-secret
WHATSAPP_CLOUD_ACCESS_TOKEN=replace-with-meta-cloud-access-token
WHATSAPP_WEBHOOK_PATH=/webhooks/whatsapp
INSTAGRAM_VERIFY_TOKEN=replace-with-instagram-webhook-verify-token
INSTAGRAM_APP_SECRET=replace-with-meta-app-secret
META_APP_ID=replace-with-meta-app-id
META_APP_SECRET=replace-with-meta-app-secret
INSTAGRAM_OAUTH_REDIRECT_URI=baas-owner://instagram-oauth
BAAS_TOKEN_ENCRYPTION_KEY=replace-with-32-byte-base64-key
NEXOLIA_AUTH_WABA_PHONE_NUMBER_ID=replace-with-platform-waba-phone-number-id
NEXOLIA_AUTH_WABA_ACCESS_TOKEN=replace-with-platform-waba-access-token
NEXOLIA_AUTH_OTP_TEMPLATE_NAME=nexolia_auth_otp
NEXOLIA_AUTH_OTP_TEMPLATE_LANGUAGE=es
BAAS_TASKS_JOB_SECRET=replace-with-random-task-job-secret

# Optional: OpenAI for Copi LLM phrasing, voice STT, and vision (Pro features)
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini

# Optional: Twilio SMS for the SMS login channel only (Supabase Auth → Phone provider)
# Do not use Twilio for WhatsApp login — that channel uses Meta via NEXOLIA_AUTH_WABA_*.
SUPABASE_AUTH_SMS_PROVIDER=twilio
SUPABASE_AUTH_SMS_PROVIDER_SECRET=configure-in-supabase-dashboard-only
