# BaaS environment example.
# Copy this file to .env.local for local development and replace placeholders.
# Never commit real secrets.

# Shared Supabase project metadata
SUPABASE_PROJECT_REF=efcyejbvcskbnipwdfge
SUPABASE_URL=https://efcyejbvcskbnipwdfge.supabase.co

# Mobile / client-safe values
EXPO_PUBLIC_SUPABASE_URL=https://efcyejbvcskbnipwdfge.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-publishable-key
EXPO_PUBLIC_AUTH_OTP_CHANNEL=sms

# Server-only values
# Use only in NestJS API, backend jobs, CI, or deployment secret stores.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_ACCESS_TOKEN=replace-with-supabase-access-token
SUPABASE_DB_PASSWORD=replace-with-database-password

# Hosted Supabase Auth phone OTP provider metadata.
# Keep real provider secrets in Supabase/dashboard secret storage only.
SUPABASE_AUTH_SMS_PROVIDER=replace-with-provider-name
SUPABASE_AUTH_SMS_PROVIDER_SECRET=replace-with-provider-secret
