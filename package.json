{
  "name": "baas-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p apps/api/tsconfig.build.json",
    "dev:api": "tsx watch apps/api/src/main.ts",
    "start:api": "tsx apps/api/src/main.ts",
    "test": "vitest run",
    "typecheck": "tsc -p apps/api/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "latest",
    "@nestjs/core": "latest",
    "@nestjs/platform-express": "latest",
    "express": "latest",
    "reflect-metadata": "latest",
    "rxjs": "latest"
  },
  "devDependencies": {
    "@types/express": "latest",
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
