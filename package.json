{
  "name": "baas-mvp",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/mobile"
  ],
  "engines": {
    "node": "22.x",
    "npm": ">=10"
  },
  "scripts": {
    "build": "npm run build -w @baas/api",
    "audit:archive": "node scripts/create-audit-archive.mjs",
    "audit:clean": "node scripts/clean-generated-artifacts.mjs --yes",
    "audit:clean:dry-run": "node scripts/clean-generated-artifacts.mjs --dry-run",
    "ci:verify": "npm run lint && npm run validate:migrations && npm run typecheck && npm test && npm run build && npm run validate:mobile",
    "dev:api": "npm run dev -w @baas/api",
    "dev:mobile": "npm run start -w @baas/mobile",
    "lint": "eslint .",
    "railway:build": "npm run build --workspace @baas/api",
    "railway:install": "npm ci --workspace @baas/api --include-workspace-root=false --include=dev",
    "railway:start": "npm run start:prod --workspace @baas/api",
    "start:api": "npm run start -w @baas/api",
    "start:api:prod": "npm run start:prod -w @baas/api",
    "test": "npm run test -w @baas/api",
    "typecheck": "npm run typecheck -w @baas/api && npm run typecheck -w @baas/mobile",
    "validate:migrations": "node scripts/validate-migrations.mjs",
    "validate:mobile": "expo config apps/mobile --type public"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.60.1"
  }
}
