{
  "name": "baas-mvp",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/mobile",
    "apps/ui-mockups"
  ],
  "engines": {
    "node": "22.x",
    "npm": ">=10"
  },
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native-safe-area-context": "5.8.0",
    "react-native-svg": "15.15.5"
  },
  "scripts": {
    "build": "npm run build -w @baas/api",
    "audit:archive": "node scripts/create-audit-archive.mjs",
    "audit:clean": "node scripts/clean-generated-artifacts.mjs --yes",
    "audit:clean:dry-run": "node scripts/clean-generated-artifacts.mjs --dry-run",
    "ci:verify": "npm run lint && npm run validate:migrations && npm run validate:rls && npm run typecheck && npm test && npm run build && npm run validate:mobile",
    "docs:openapi": "npm run docs:openapi --workspace @baas/api -- ../../docs/developer/openapi.json",
    "dev:api": "npm run dev -w @baas/api",
    "dev:mobile": "npm run start -w @baas/mobile",
    "dev:ui-mockups": "npm run dev -w @baas/ui-mockups",
    "lint": "eslint .",
    "railway:build": "npm run build --workspace @baas/api",
    "railway:install": "npm ci --workspace @baas/api --include-workspace-root=false --include=dev",
    "railway:start": "npm run start:prod --workspace @baas/api",
    "start:api": "npm run start -w @baas/api",
    "start:api:prod": "npm run start:prod -w @baas/api",
    "test": "npm run test -w @baas/api",
    "typecheck": "npm run typecheck -w @baas/api && npm run typecheck -w @baas/mobile && npm run typecheck -w @baas/ui-mockups",
    "validate:migrations": "node scripts/validate-migrations.mjs",
    "validate:rls": "node scripts/validate-rls-coverage.mjs",
    "validate:mobile": "expo config apps/mobile --type public",
    "build:android:preview": "npm run build:android:preview -w @baas/mobile",
    "build:android:production": "npm run build:android:production -w @baas/mobile",
    "build:android:development": "npm run build:android:development -w @baas/mobile"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.60.1"
  }
}
