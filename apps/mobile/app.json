{
  "expo": {
    "name": "BaaS Owner",
    "slug": "baas-owner",
    "scheme": "baas-owner",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/nexolia-icon.png",
    "splash": {
      "image": "./assets/images/nexolia-mark.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/nexolia-notification-icon.png",
          "color": "#08bd66",
          "defaultChannel": "tareas"
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Nexolia usa el micrófono para que Copi transcriba tus preguntas de voz.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Nexolia usa la cámara para escanear códigos de productos, fotos de perfil y para que Copi analice productos.",
          "photosPermission": "Nexolia accede a tus fotos para actualizar tu perfil y para que Copi analice imágenes del negocio."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Nexolia usa contactos para invitar miembros del equipo y agregar clientes."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Nexolia usa la cámara para escanear códigos de barras y QR de productos.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      "expo-secure-store"
    ],
    "ios": {
      "bundleIdentifier": "com.nexolia.owner",
      "supportsTablet": true
    },
    "android": {
      "package": "com.nexolia.owner",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/nexolia-adaptive-foreground.png",
        "backgroundColor": "#0f172a",
        "monochromeImage": "./assets/images/nexolia-notification-icon.png"
      },
      "blockedPermissions": [
        "android.permission.WRITE_CONTACTS"
      ],
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CONTACTS",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "baas-owner"
            }
          ]
        }
      ],
      "navigationBar": {
        "backgroundColor": "#ffffff",
        "barStyle": "dark-content"
      }
    },
    "extra": {
      "phase": "0",
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    },
    "androidStatusBar": {
      "backgroundColor": "#0f172a",
      "barStyle": "light-content",
      "translucent": true
    }
  }
}
