{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Nexolia Developer Docs",
  "description": "API and webhook documentation for the Nexolia BaaS platform.",
  "colors": {
    "primary": "#0A9E56",
    "light": "#F3FBF7",
    "dark": "#087A44"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "index",
              "guides/authentication",
              "guides/environments",
              "guides/error-handling",
              "guides/rate-limits",
              "guides/webhooks"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Nexolia API",
            "openapi": "openapi.json"
          }
        ]
      }
    ]
  },
  "api": {
    "openapi": {
      "source": "openapi.json",
      "directory": "api-reference"
    },
    "playground": {
      "display": "interactive",
      "proxy": true
    },
    "params": {
      "expanded": "all"
    },
    "url": "full",
    "examples": {
      "languages": ["curl", "javascript", "python"],
      "defaults": "required",
      "prefill": true,
      "autogenerate": true
    }
  }
}
